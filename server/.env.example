# Copy to .env and adjust.

DJANGO_SECRET_KEY=change-me-in-development
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Database
#
# SQLite (default): omit DATABASE_BACKEND or set:
# DATABASE_BACKEND=sqlite
#
# PostgreSQL: set DATABASE_BACKEND=postgresql and the connection fields below.
# Requires the psycopg package (see server/requirements.txt).
#
# DATABASE_BACKEND=postgresql
# POSTGRES_DB=osolot
# POSTGRES_USER=osolot
# POSTGRES_PASSWORD=change-me
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
#
# Optional SSL (e.g. managed Postgres): set to require or verify-full
# POSTGRES_SSLMODE=require
