{
  "openapi": "3.1.0",
  "info": {
    "title": "Osolot API",
    "version": "1.0.0",
    "description": "Account and profile endpoints (JWT)."
  },
  "paths": {
    "/api/auth/register": {
      "post": {
        "operationId": "users_routes_register",
        "summary": "Register",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPairOut"
                }
              }
            }
          }
        },
        "tags": [
          "auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterIn"
              }
            }
          },
          "required": true
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "operationId": "users_routes_login",
        "summary": "Login",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TokenPairOut"
                }
              }
            }
          }
        },
        "tags": [
          "auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginIn"
              }
            }
          },
          "required": true
        }
      }
    },
    "/api/auth/refresh": {
      "post": {
        "operationId": "users_routes_refresh",
        "summary": "Refresh",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AccessTokenOut"
                }
              }
            }
          }
        },
        "tags": [
          "auth"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RefreshIn"
              }
            }
          },
          "required": true
        }
      }
    },
    "/api/users/me": {
      "get": {
        "operationId": "users_routes_me",
        "summary": "Me",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserOut"
                }
              }
            }
          }
        },
        "tags": [
          "users"
        ],
        "security": [
          {
            "JWTAuth": []
          }
        ]
      },
      "patch": {
        "operationId": "users_routes_update_me",
        "summary": "Update Me",
        "parameters": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/UserOut"
                }
              }
            }
          }
        },
        "tags": [
          "users"
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/UserUpdateIn"
              }
            }
          },
          "required": true
        },
        "security": [
          {
            "JWTAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "TokenPairOut": {
        "properties": {
          "access": {
            "title": "Access",
            "type": "string"
          },
          "refresh": {
            "title": "Refresh",
            "type": "string"
          }
        },
        "required": [
          "access",
          "refresh"
        ],
        "title": "TokenPairOut",
        "type": "object"
      },
      "RegisterIn": {
        "properties": {
          "username": {
            "maxLength": 150,
            "minLength": 1,
            "title": "Username",
            "type": "string"
          },
          "password": {
            "minLength": 8,
            "title": "Password",
            "type": "string"
          },
          "email": {
            "anyOf": [
              {
                "maxLength": 254,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Email"
          },
          "name": {
            "default": "",
            "maxLength": 255,
            "title": "Name",
            "type": "string"
          }
        },
        "required": [
          "username",
          "password"
        ],
        "title": "RegisterIn",
        "type": "object"
      },
      "LoginIn": {
        "properties": {
          "username": {
            "title": "Username",
            "type": "string"
          },
          "password": {
            "title": "Password",
            "type": "string"
          }
        },
        "required": [
          "username",
          "password"
        ],
        "title": "LoginIn",
        "type": "object"
      },
      "AccessTokenOut": {
        "properties": {
          "access": {
            "title": "Access",
            "type": "string"
          }
        },
        "required": [
          "access"
        ],
        "title": "AccessTokenOut",
        "type": "object"
      },
      "RefreshIn": {
        "properties": {
          "refresh": {
            "title": "Refresh",
            "type": "string"
          }
        },
        "required": [
          "refresh"
        ],
        "title": "RefreshIn",
        "type": "object"
      },
      "UserOut": {
        "properties": {
          "id": {
            "title": "Id",
            "type": "integer"
          },
          "username": {
            "title": "Username",
            "type": "string"
          },
          "email": {
            "title": "Email",
            "type": "string"
          },
          "name": {
            "title": "Name",
            "type": "string"
          }
        },
        "required": [
          "id",
          "username",
          "email",
          "name"
        ],
        "title": "UserOut",
        "type": "object"
      },
      "UserUpdateIn": {
        "properties": {
          "name": {
            "anyOf": [
              {
                "maxLength": 255,
                "type": "string"
              },
              {
                "type": "null"
              }
            ],
            "title": "Name"
          }
        },
        "title": "UserUpdateIn",
        "type": "object"
      }
    },
    "securitySchemes": {
      "JWTAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "servers": []
}